{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo MANDATORY: Read .adn/lessons.md IN FULL before any work. Same mistake twice = broken process."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*package.json)|Edit(*package.json)",
            "command": "node scripts/generate-commands-doc.js 2>/dev/null || true",
            "statusMessage": "Regenerating docs/COMMANDS.md..."
          },
          {
            "type": "command",
            "if": "Write(*.adn/features/*.md)|Edit(*.adn/features/*.md)|Write(*.adn/flow/*.md)|Edit(*.adn/flow/*.md)",
            "command": "node scripts/build-chaos-catalog.js 2>/dev/null || true",
            "statusMessage": "Regenerating chaos catalog..."
          }
        ]
      }
    ]
  }
}

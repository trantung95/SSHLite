FROM alpine:3.19

RUN apk add --no-cache openssh-server bash coreutils findutils grep sudo

# Create test users
RUN adduser -D -s /bin/bash testuser && echo "testuser:testpass" | chpasswd
RUN adduser -D -s /bin/bash admin && echo "admin:adminpass" | chpasswd

# v0.8.15: give testuser NOPASSWD sudo so chaos primitives (sudoWriteFile /
# sudoReadFile / sudoExec) can exercise the stderr-sync protocol on basic
# chaos servers (ports 2201-2203 + multios-alpine 2210). Test-container only.
RUN mkdir -p /etc/sudoers.d && chmod 750 /etc/sudoers.d && \
    echo 'testuser ALL=(ALL) NOPASSWD: ALL' > /etc/sudoers.d/testuser && \
    chmod 0440 /etc/sudoers.d/testuser

# Generate host keys
RUN ssh-keygen -A

# Configure sshd: allow password auth, no PAM
RUN sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' /etc/ssh/sshd_config && \
    echo "UsePAM no" >> /etc/ssh/sshd_config && \
    echo "Subsystem sftp /usr/lib/ssh/sftp-server" >> /etc/ssh/sshd_config

# Create test directories and files for each user
RUN mkdir -p /home/testuser/projects/src && \
    echo 'console.log("hello world");' > /home/testuser/projects/src/app.ts && \
    echo '{"name":"test"}' > /home/testuser/projects/package.json && \
    echo 'TODO: fix bug' > /home/testuser/projects/src/todo.ts && \
    mkdir -p /home/testuser/logs && \
    echo '[2024-01-01] Server started' > /home/testuser/logs/app.log && \
    mkdir -p /home/testuser/big && \
    dd if=/dev/zero of=/home/testuser/big/huge.log bs=1M count=10 2>/dev/null && \
    chown -R testuser:testuser /home/testuser

RUN mkdir -p /home/admin/configs && \
    echo 'server.port=8080' > /home/admin/configs/server.conf && \
    echo 'db.host=localhost' > /home/admin/configs/db.conf && \
    mkdir -p /home/admin/scripts && \
    echo '#!/bin/bash\necho "deploy complete"' > /home/admin/scripts/deploy.sh && \
    chmod +x /home/admin/scripts/deploy.sh && \
    chown -R admin:admin /home/admin

# Layer a rich, diverse "showcase" file tree on top of the minimal fixtures
# above. The fixtures above are kept verbatim for backward-compat with the
# docker-ssh.test.ts / multios assertions; this only ADDS content (showcase/
# + workspace/ + hidden dotfiles), it never removes the legacy files.
# SERVER_FLAVOR (prod-web | prod-api | prod-db) decorates the workspace dir so
# each server gets a distinct top-level project. Default prod-db for any image
# (e.g. multios-alpine) that doesn't pass the arg.
ARG SERVER_FLAVOR=prod-db
COPY seed-showcase.sh /usr/local/bin/seed-showcase.sh
RUN chmod +x /usr/local/bin/seed-showcase.sh && \
    bash /usr/local/bin/seed-showcase.sh "$SERVER_FLAVOR"

RUN mkdir -p /var/log/sshd

EXPOSE 22

# Log to both stderr (docker logs) and /var/log/sshd/sshd.log (volume mount)
CMD ["/bin/sh", "-c", "/usr/sbin/sshd -D -e 2>&1 | tee /var/log/sshd/sshd.log"]
